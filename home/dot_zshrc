# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.

# Silence direnv logging
export DIRENV_LOG_FORMAT=""

# --- Oh My Zsh ---
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME=""
plugins=(git zsh-autosuggestions z)
source $ZSH/oh-my-zsh.sh

# --- Secrets (tokens, API keys) ---
[[ -f ~/.zshrc.secrets ]] && source ~/.zshrc.secrets
[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local

# --- Environment ---
export JAVA_HOME=/Library/Java/JavaVirtualMachines/zulu-17.jdk/Contents/Home
export ANDROID_HOME=$HOME/Library/Android/sdk
export EDITOR="nvim"
export VISUAL="nvim"

# --- PATH ---
export PATH=$PATH:$ANDROID_HOME/emulator
export PATH=$PATH:$ANDROID_HOME/platform-tools
export PATH=$PATH:$HOME/.maestro/bin

# --- Terminal ---
if [[ "$TERM_PROGRAM" == "ghostty" ]]; then
  export TERM=xterm-ghostty
fi
export COLORTERM=truecolor

# --- Aliases ---
alias cc='claude'
alias dcc='claude --permission-mode bypassPermissions'
alias fcc='claude --permission-mode bypassPermissions --print'
alias jcc='claude --permission-mode bypassPermissions --output-format stream-json --include-partial-messages --verbose --print'

tmpd() { cd "$(mktemp -d)"; }
markd() { cmux markdown open "$@"; }

# 3-panel cmux layout: Agent (left), Console (top-right), Logs (bottom-right)
cmux-layout() {
  local dir="${1:-.}"
  local name="${2:-$(basename "$(realpath "$dir")")}"
  cmux new-workspace --cwd "$dir" --command '
    cmux rename-workspace "'"$name"'" &&
    cmux rename-tab --surface $CMUX_SURFACE_ID Agent &&
    console=$(cmux new-split right | grep -oE "surface:[0-9]+") &&
    cmux rename-tab --surface $console Console &&
    logs=$(cmux new-split down --surface $console | grep -oE "surface:[0-9]+") &&
    cmux rename-tab --surface $logs Logs &&
    cmux focus-pane --pane $(cmux identify | jq -r .focused.pane_ref) &&
    cc
  '
}

# --- Prompt ---
eval "$(oh-my-posh init zsh --config ~/.config/oh-my-posh/theme.omp.json)"

# --- Tools ---
eval "$(zoxide init zsh)"


# --- Completions ---
fpath=(~/.zsh/completions $fpath)
autoload -U compinit && compinit

# --- Direnv (must be last) ---
eval "$(direnv hook zsh)"

export PATH="$HOME/.local/share/mise/shims:$PATH"

# Kiro CLI pre block. Keep at the top of this file.
[[ -f "${HOME}/Library/Application Support/kiro-cli/shell/zshrc.pre.zsh" ]] && builtin source "${HOME}/Library/Application Support/kiro-cli/shell/zshrc.pre.zsh"
# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# Add Homebrew to PATH (Apple Silicon default)
export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:$PATH"

# Path to your Oh My Zsh installation.
export ZSH="$HOME/.oh-my-zsh"

# ZSH Theme
ZSH_THEME="powerlevel10k/powerlevel10k"

# Oh My Zsh plugins
plugins=(git zsh-autosuggestions zsh-syntax-highlighting web-search z)

source $ZSH/oh-my-zsh.sh

# --- Universal Settings & Aliases ---

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

source /opt/homebrew/opt/autoenv/activate.sh

alias zshconfig="code ~/.zshrc"
alias shell="code ~/.zshrc"

# --- Secret Management ---
# Secrets are loaded securely via chezmoi and your chosen secret manager.
# The following paths are examples for 1Password. Update them for your setup.

# OpenAI
export OPENAI_API_KEY="{{ onepasswordRead "op://private/openai/api-key" }}"

# Sentry
export SENTRY_API_TOKEN="{{ onepasswordRead "op://private/sentry/api-token" }}"
# The SENTRY_COOKIE is long and might be better stored in a file read by chezmoi,
# but for now, you can add it to your secret manager.
# export SENTRY_COOKIE="{{ onepasswordRead "op://private/sentry/cookie" }}"

# Flatfile
export PAT_FLATFILE_TOKEN="{{ onepasswordRead "op://private/flatfile/pat" }}"

# --- Context-Specific Loading ---

# Load work-specific settings only when in the 'gusto' context
{{ if eq .chezmoi.context "gusto" -}}
if [ -f ~/.zshrc-work ]; then
  source ~/.zshrc-work
fi
{{- end }}

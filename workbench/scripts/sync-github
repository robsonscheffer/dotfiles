#!/usr/bin/env ruby
# frozen_string_literal: true

# sync-github — Sync all tickets' PR state from GitHub
# Contract: stdout=JSON, stderr=human log, exit 0=success

$LOAD_PATH.unshift(File.expand_path("../lib", __dir__))

require "workbench"
require "json"

registry = Workbench::Registry.new
github = Workbench::GithubSync.new(registry: registry)
result = github.sync_all
puts JSON.pretty_generate(result)

#!/usr/bin/env bash
# Pre-commit hook: block commits containing denied patterns.
# Patterns are loaded from .denied-patterns (one regex per line).

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
PATTERNS_FILE="$REPO_ROOT/.denied-patterns"

if [[ ! -f "$PATTERNS_FILE" ]]; then
  exit 0
fi

# Build grep pattern from non-empty, non-comment lines
pattern=""
while IFS= read -r line; do
  line="${line%%#*}"        # strip inline comments
  line="${line// /}"        # trim spaces
  [[ -z "$line" ]] && continue
  if [[ -z "$pattern" ]]; then
    pattern="$line"
  else
    pattern="$pattern|$line"
  fi
done < "$PATTERNS_FILE"

[[ -z "$pattern" ]] && exit 0

# Check staged diff (additions only), excluding the patterns file itself
matches=$(git diff --cached --diff-filter=d -U0 -- . ':!.denied-patterns' | grep '^+' | grep -v "^+++" | grep -Ei "$pattern" || true)

if [[ -n "$matches" ]]; then
  echo "Pre-commit: denied pattern found in staged changes!"
  echo ""
  echo "Patterns: $pattern"
  echo ""
  echo "Matches:"
  echo "$matches"
  echo ""
  echo "Remove these references before committing."
  echo "To bypass (emergency only): git commit --no-verify"
  exit 1
fi

# Prettier: format staged files (skips unknown extensions via --ignore-unknown)
staged_prettier_files=()
while IFS= read -r f; do
  [[ -n "$f" ]] && staged_prettier_files+=("$f")
done < <(git diff --cached --name-only --diff-filter=ACMR)

if [[ ${#staged_prettier_files[@]} -gt 0 ]] && command -v npx &>/dev/null; then
  # Collect unstaged files to detect partial staging
  unstaged_files=()
  while IFS= read -r f; do
    [[ -n "$f" ]] && unstaged_files+=("$f")
  done < <(git diff --name-only)

  prettier_to_format=()
  for file in "${staged_prettier_files[@]}"; do
    skip=0
    for unstaged in "${unstaged_files[@]+"${unstaged_files[@]}"}"; do
      if [[ "$file" == "$unstaged" ]]; then
        skip=1
        break
      fi
    done
    if [[ "$skip" -eq 0 ]]; then
      prettier_to_format+=("$file")
    else
      echo "prettier: skipping partially staged file: $file"
    fi
  done

  if [[ ${#prettier_to_format[@]} -gt 0 ]]; then
    echo "prettier: formatting ${#prettier_to_format[@]} staged file(s)..."
    npx --yes prettier --ignore-unknown --write "${prettier_to_format[@]}"
    git add "${prettier_to_format[@]}"
  fi
elif [[ ${#staged_prettier_files[@]} -gt 0 ]]; then
  echo "prettier: skipping (npx not found — install Node.js to enable prettier autoformat)"
fi
